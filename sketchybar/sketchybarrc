#!/bin/bash

sketchybar --bar \
  position=top \
  height=28 \
  color=0xff1e1e2e \
  shadow=off \
  sticky=on \
  padding_left=8 \
  padding_right=8

sketchybar --default \
  label.font="SF Mono:Bold:12.0" \
  label.padding_left=10 \
  label.padding_right=10 \
  background.height=20 \
  background.corner_radius=5

sketchybar --add event aerospace_workspace_change

# Read workspace order directly from aerospace keybindings — no manual sync needed
WORKSPACES=$(grep -E "^ctrl-alt-[0-9]+ = 'workspace " ~/.aerospace.toml \
  | sort -V \
  | sed "s/.*workspace \([^']*\)'.*/\1/")

for sid in $WORKSPACES; do
  sketchybar --add item "space.$sid" center \
    --subscribe "space.$sid" aerospace_workspace_change \
    --set "space.$sid" \
      label="$sid" \
      label.color=0xff585b70 \
      background.color=0x00000000 \
      background.drawing=off \
      click_script="/opt/homebrew/bin/aerospace workspace $sid" \
      script="$HOME/.config/sketchybar/plugins/workspace.sh"
done

sketchybar --update
